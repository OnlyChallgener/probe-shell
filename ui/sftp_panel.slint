import { Theme } from "theme.slint";
import { ScrollView } from "std-widgets.slint";

// ---------------------------------------------------------------------------
// Data types
// ---------------------------------------------------------------------------

export struct SftpEntry {
    name: string,
    full-path: string,
    is-dir: bool,
    size: string,
    modified: string,
    mode: int,        // POSIX permission bits, for the chmod dialog (#84)
    selected: bool,   // multi-select checkbox state (#100)
}

export struct SftpTreeNode {
    path: string,
    name: string,
    depth: int,
    expanded: bool,
    has-children: bool,
    checked: bool,     // true when covered by the recursive tree selection scope
}

// One row of the file-list right-click context menu.
component SftpMenuItem inherits Rectangle {
    in property <string> label;
    in property <brush> tint: Theme.text-primary;
    in property <bool> enabled: true;   // disabled items grey out + ignore clicks
    callback clicked();
    height: 26px;
    border-radius: Theme.radius-sm;
    background: (root.enabled && ta.has-hover) ? Theme.bg-hover : transparent;
    ta := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { if (root.enabled) { root.clicked(); } }
    }
    Text {
        x: 10px;
        text: root.label;
        color: root.enabled ? root.tint : Theme.text-muted;
        font-size: Theme.fs-sm;
        vertical-alignment: center;
        height: parent.height;
    }
}

// ---------------------------------------------------------------------------
// SftpPanel — left directory tree + right file listing
// ---------------------------------------------------------------------------

export component SftpPanel inherits Rectangle {
    // --- Properties --------------------------------------------------------
    in property <string>  current-path: "/";
    in property <[SftpEntry]>    entries;
    in property <string>  status: @tr("SFTP not connected");
    in property <bool>    loading: false;
    in property <[SftpTreeNode]> tree-nodes: [];
    in property <bool> collapsed: false;   // when true only the toolbar shows
    in property <string> search-query: ""; // file/folder search text, filtered in Rust
    in property <string> tree-scope: "";   // recursive folder selection / search scope, owned by Rust
    in property <bool> show-tree: true;    // hide the directory tree when narrow (#dock)
    in property <bool> compact: false;     // side-docked + collapsed → render nothing but a clean strip (#dock)
    // User-resizable directory tree width. This is intentionally local to the
    // panel, so it is safe and never affects terminal layout.
    property <length> tree-width: 180px;
    property <bool> tree-resizing: false;
    property <length> tree-grab-x;
    property <length> tree-base-width;
    // Responsive columns: only when docked left/right (narrow, width-adjustable).
    // Docked top/bottom the panel is wide and can only be resized vertically, so
    // always show every column there (show-tree is true exactly in that case).
    // When narrow, drop Size then Modified the moment keeping them would squeeze
    // the Name column below `name-min` (names start eliding to "…"). Reserved
    // widths: checkbox+padding+spacing 36px, Size col 76px, Modified 120px.
    property <length> list-w: root.show-tree ? root.width - root.tree-width - 6px : root.width;
    property <length> name-min: 180px;     // narrower than this → start dropping columns
    property <bool> show-size-col: root.show-tree || (root.list-w - 36px - 76px - 120px > root.name-min);
    property <bool> show-modified-col: root.show-tree || (root.list-w - 36px - 120px > root.name-min);
    property <int> selected-row: -1;       // clicked/highlighted file-list row (#70)
    in property <int> selected-count;      // number of checked entries (#100)
    // Panel-level right-click context menu (#84). One menu for the whole list:
    // an empty `menu-target` means the click landed on whitespace, which greys
    // out the item-specific actions (download/rename/…) but keeps new/refresh.
    property <length> menu-x;
    property <length> menu-y;
    property <string> menu-target;          // "" = whitespace
    property <string> menu-target-name;
    property <bool>   menu-target-is-dir;
    property <int>    menu-target-mode;     // permission bits for the chmod dialog
    property <int>    menu-target-index: -1; // row index for checkbox/multi-select actions
    // Directory-tree selection is separate from the right file-list checkbox.
    // It acts as a search scope: check one folder in the tree, then use the
    // small folder-search button or press Enter in the search box (#probe-folder-search).
    property <string> tree-active-path: ""; // single-clicked tree row; selection only, not navigation
    property <length> tree-menu-x;
    property <length> tree-menu-y;
    property <string> tree-menu-target;
    property <string> toolbar-tip: ""; // hover hint for compact icon buttons

    // --- Callbacks ---------------------------------------------------------
    callback toggle-collapsed();    // minimise / restore the panel
    callback navigate(string);
    callback download(string);
    callback upload-clicked(string /* remote dir */, bool /* folder */);
    callback refresh(string);
    callback search-changed(string); // filter files/folders in current directory
    callback search-folder(string /* root dir */, string /* query */); // recursive search from a selected/current folder
    callback cancel-search();       // stop the currently running recursive search
    callback tree-expand(string);   // toggle expand/collapse only; never navigates
    callback toggle-tree-scope(string); // recursive checkbox selection/search scope
    callback delete(string);        // remove a remote file/dir
    callback toggle-select(int);    // toggle a row's multi-select checkbox (#100)
    callback download-selected();   // download all checked entries (#100)
    callback delete-selected();     // delete all checked entries (#100)
    callback view(string);          // open read-only in the built-in viewer
    callback edit(string);          // open writable in the built-in editor
    callback open-external(string);     // open with the OS default app (#81)
    callback edit-external(string);     // open externally + watch/re-upload (#81)
    // Context-menu extensions (#69). The *-request callbacks open dialogs in
    // the app shell; copy-path goes straight to the system clipboard.
    callback rename-request(string /* path */, string /* current name */);
    callback chmod-request(string /* path */, string /* name */, int /* mode */);
    callback copy-path(string);
    callback new-folder(string /* parent dir */);
    callback new-file(string /* parent dir */);
    callback open-operation-log();
    // Drag-to-dock: empty areas of the panel are a grab handle; coordinates are
    // reported in window space so the parent can compute the target edge (#dock).
    callback dock-drag-move(length /* abs-x */, length /* abs-y */);
    callback dock-drag-end();

    // -----------------------------------------------------------------------
    background: Theme.bg-panel;

    // Keep the editable path bar in sync when the directory changes elsewhere
    // (tree click, file double-click, terminal cd) (#54).
    changed current-path => { path-input.text = root.current-path; root.selected-row = -1; }

    // Drag empty space to re-dock; interactive widgets (file list, tree, toolbar
    // buttons) sit in front and capture their own events (#dock).
    dock-bg := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: move;
        moved => {
            root.dock-drag-move(self.absolute-position.x + self.mouse-x,
                                self.absolute-position.y + self.mouse-y);
        }
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.up) { root.dock-drag-end(); }
        }
    }

    // Hidden entirely when side-docked + collapsed: the horizontal toolbar would
    // otherwise squish into an unusable vertical strip. `visible` (not `if`) so
    // ids like path-input stay accessible to handlers. The parent floats a clean
    // expand button over this (#dock).
    VerticalLayout {
        visible: !root.compact;
        spacing: 0;

        // --- Toolbar (full width) ------------------------------------------
        Rectangle {
            height: 30px;
            background: Theme.bg-panel-alt;

            HorizontalLayout {
                padding-left: 6px;
                padding-right: 6px;
                spacing: 4px;

                // Dedicated drag handle to re-dock the panel. The toolbar is full
                // of controls, so dragging "empty space" is unreliable; this grip
                // is always grabbable and reports window-space coords (#dock).
                Rectangle {
                    width: 16px;
                    y: (parent.height - self.height) / 2;
                    height: 22px;
                    grip-ta := TouchArea {
                        mouse-cursor: move;
                        moved => {
                            root.dock-drag-move(self.absolute-position.x + self.mouse-x,
                                                self.absolute-position.y + self.mouse-y);
                        }
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.up) { root.dock-drag-end(); }
                        }
                    }
                    Text {
                        text: "\u{E945}";   // drag_indicator
                        font-family: "Material Icons";
                        color: grip-ta.has-hover ? Theme.text-secondary : Theme.text-muted;
                        font-size: 16px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }

                // Editable path bar: type or paste a path and press Enter to
                // jump there; copy / paste-jump buttons sit right after it (#54).
                Rectangle {
                    horizontal-stretch: 1;
                    height: 22px;
                    border-radius: Theme.radius-sm;
                    background: Theme.bg-root;
                    border-width: 1px;
                    border-color: path-input.has-focus ? Theme.accent : Theme.border-subtle;
                    path-input := TextInput {
                        x: 6px;
                        width: parent.width - 12px;
                        height: parent.height;
                        text: root.current-path;
                        color: Theme.text-primary;
                        // CJK-capable font so typed Chinese isn't tofu (#54).
                        font-family: Theme.ui-font-family;
                        font-size: Theme.fs-sm;
                        vertical-alignment: center;
                        single-line: true;
                        accepted => { root.navigate(self.text); }
                    }
                }

                // Search within the current remote directory. Filtering happens in
                // Rust against the last full directory listing, so it is instant and
                // does not touch the network. Kept compact to avoid stealing space
                // from the path bar on small windows.
                Rectangle {
                    width: root.width > 900px ? 180px : 128px;
                    height: 22px;
                    border-radius: Theme.radius-sm;
                    background: Theme.bg-root;
                    border-width: 1px;
                    border-color: file-search.has-focus ? Theme.accent : Theme.border-subtle;
                    file-search := TextInput {
                        x: 24px;
                        width: parent.width - 30px;
                        height: parent.height;
                        text: root.search-query;
                        color: Theme.text-primary;
                        font-family: Theme.ui-font-family;
                        font-size: Theme.fs-sm;
                        vertical-alignment: center;
                        single-line: true;
                        // Typing filters the current visible listing only, so it stays instant.
                        edited => { root.search-changed(self.text); }
                        // Enter performs a scoped search: checked tree folder first, otherwise current path.
                        accepted => {
                            root.search-folder(
                                root.tree-scope != "" ? root.tree-scope : root.current-path,
                                self.text
                            );
                        }
                    }
                    Text {
                        x: 6px;
                        width: 16px;
                        height: parent.height;
                        text: "\u{E8B6}"; // search
                        font-family: "Material Icons";
                        color: Theme.text-muted;
                        font-size: Theme.fs-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    if file-search.text == "" : Text {
                        x: 24px;
                        width: parent.width - 30px;
                        height: parent.height;
                        text: root.tree-scope != "" ? @tr("搜索勾选目录") : @tr("搜索当前目录");
                        color: Theme.text-muted;
                        font-size: Theme.fs-xs;
                        vertical-alignment: center;
                    }
                }

                // Scoped search: if a directory in the tree is checked, search there;
                // otherwise search the current path. Kept as a compact icon so it
                // doesn't crowd the path bar (#probe-folder-search).
                Rectangle {
                    width: 24px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: fs-ta.has-hover ? Theme.bg-hover : transparent;
                    fs-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("搜索文件/文件夹（递归）") : ""; }
                        clicked => {
                            root.search-folder(
                                root.tree-scope != "" ? root.tree-scope : root.current-path,
                                file-search.text
                            );
                        }
                    }
                    Text { text: "\u{F02F}"; font-family: "Material Icons";
                           color: root.tree-scope != "" ? Theme.accent : Theme.text-secondary;
                           font-size: Theme.fs-sm; horizontal-alignment: center; vertical-alignment: center; }
                }

                // Stop an active recursive search. Always available: if no search is running
                // Rust will just report "当前没有正在运行的搜索". Keeping the button visible
                // avoids the confusing "where do I stop it" state while a remote walk is busy.
                Rectangle {
                    width: 34px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: stop-search-ta.has-hover ? Theme.danger.with-alpha(0.18) : transparent;
                    stop-search-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("停止正在运行的文件搜索") : ""; }
                        clicked => { root.cancel-search(); }
                    }
                    Text { text: @tr("停止"); color: Theme.danger; font-size: Theme.fs-xs;
                           horizontal-alignment: center; vertical-alignment: center; }
                }

                // Open the local operation log. The log records file operations
                // such as create/delete/edit/chmod/download/upload with timestamp.
                Rectangle {
                    width: 24px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: oplog-ta.has-hover ? Theme.bg-hover : transparent;
                    oplog-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("打开本地操作日志") : ""; }
                        clicked => { root.open-operation-log(); }
                    }
                    Text { text: "\u{E889}"; font-family: "Material Icons";
                           color: Theme.text-secondary; font-size: Theme.fs-sm;
                           horizontal-alignment: center; vertical-alignment: center; }
                }

                // Copy the current path to the clipboard.
                Rectangle {
                    width: 24px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: copy-ta.has-hover ? Theme.bg-hover : transparent;
                    copy-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("复制当前路径") : ""; }
                        clicked => {
                            path-input.select-all();
                            path-input.copy();
                            path-input.clear-selection();
                        }
                    }
                    Text { text: "\u{E14D}"; font-family: "Material Icons";
                           color: Theme.text-secondary; font-size: Theme.fs-sm;
                           horizontal-alignment: center; vertical-alignment: center; }
                }

                // Paste a path from the clipboard and jump straight to it.
                Rectangle {
                    width: 24px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: pj-ta.has-hover ? Theme.bg-hover : transparent;
                    pj-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("粘贴路径并跳转") : ""; }
                        clicked => {
                            path-input.select-all();
                            path-input.paste();
                            root.navigate(path-input.text);
                        }
                    }
                    Text { text: "\u{E14F}"; font-family: "Material Icons";
                           color: Theme.text-secondary; font-size: Theme.fs-sm;
                           horizontal-alignment: center; vertical-alignment: center; }
                }

                up-btn := Rectangle {
                    width: 24px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: up-ta.has-hover ? Theme.bg-hover : transparent;
                    up-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("返回上一级目录") : ""; }
                        clicked => { root.navigate(".."); }
                    }
                    Text { text: "↑"; color: Theme.text-secondary; font-size: Theme.fs-md;
                           horizontal-alignment: center; vertical-alignment: center; }
                }

                // Upload: a small menu offers file vs folder (#85). The remote
                // SFTP upload handles both — only the local picker differs.
                ul-btn := Rectangle {
                    width: 52px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: ul-ta.has-hover ? Theme.accent-hover : Theme.accent;
                    ul-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("上传文件或文件夹") : ""; }
                        clicked => { ul-menu.show(); }
                    }
                    Text { text: @tr("Upload"); color: #ffffff; font-size: Theme.fs-sm;
                           horizontal-alignment: center; vertical-alignment: center; }
                    ul-menu := PopupWindow {
                        x: 0; y: parent.height + 2px;
                        width: 124px;
                        height: 2 * 27px + 8px;
                        Rectangle {
                            background: Theme.bg-panel;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: Theme.border-strong;
                            drop-shadow-blur: 12px;
                            drop-shadow-color: #00000060;
                            VerticalLayout {
                                padding: 4px;
                                spacing: 1px;
                                SftpMenuItem {
                                    label: @tr("Upload file");
                                    clicked => { root.upload-clicked(root.current-path, false); }
                                }
                                SftpMenuItem {
                                    label: @tr("Upload folder");
                                    clicked => { root.upload-clicked(root.current-path, true); }
                                }
                            }
                        }
                    }
                }

                // Batch actions on checked entries — only when something's checked (#100).
                if root.selected-count > 0 : Text {
                    text: "✓" + root.selected-count;
                    color: Theme.accent;
                    font-size: Theme.fs-sm;
                    vertical-alignment: center;
                }
                if root.selected-count > 0 : Rectangle {
                    width: 24px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: dls-ta.has-hover ? Theme.bg-hover : transparent;
                    dls-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("下载已勾选项目") : ""; }
                        clicked => { root.download-selected(); }
                    }
                    Text { text: "\u{E2C4}"; font-family: "Material Icons"; color: Theme.text-secondary;
                           font-size: Theme.fs-md; horizontal-alignment: center; vertical-alignment: center; }
                }
                if root.selected-count > 0 : Rectangle {
                    width: 24px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: dels-ta.has-hover ? Theme.danger.with-alpha(0.18) : transparent;
                    dels-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("删除已勾选项目") : ""; }
                        clicked => { root.delete-selected(); }
                    }
                    Text { text: "\u{E872}"; font-family: "Material Icons"; color: Theme.danger;
                           font-size: Theme.fs-md; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    width: 24px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: ref-ta.has-hover ? Theme.bg-hover : transparent;
                    ref-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("刷新当前目录") : ""; }
                        clicked => { root.refresh(root.current-path); }
                    }
                    Text { text: "\u{E5D5}"; font-family: "Material Icons";
                           color: Theme.text-secondary; font-size: Theme.fs-sm;
                           horizontal-alignment: center; vertical-alignment: center; }
                }

                // Minimise / restore the SFTP panel (#41).
                Rectangle {
                    width: 24px; height: 22px;
                    border-radius: Theme.radius-sm;
                    background: min-ta.has-hover ? Theme.bg-hover : transparent;
                    min-ta := TouchArea {
                        mouse-cursor: pointer;
                        changed has-hover => { root.toolbar-tip = self.has-hover ? @tr("折叠/展开文件面板") : ""; }
                        clicked => { root.toggle-collapsed(); }
                    }
                    // expand_less (▲, restore) when collapsed, expand_more (▼) otherwise.
                    Text { text: root.collapsed ? "\u{E5CE}" : "\u{E5CF}"; font-family: "Material Icons";
                           color: Theme.text-secondary; font-size: Theme.fs-md;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        // --- Main area: tree (left) + file list (right) --------------------
        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0;

            // ── Left: directory tree (hidden when the panel is narrow) ──────
            if root.show-tree : VerticalLayout {
                width: root.tree-width;
                spacing: 0;

                // Tree header
                Rectangle {
                    height: 20px;
                    background: Theme.bg-root;
                    Text {
                        x: 8px;
                        text: @tr("Directory tree");
                        color: Theme.text-muted;
                        font-size: Theme.fs-xs;
                        vertical-alignment: center;
                        height: parent.height;
                    }
                }
                Rectangle { height: 1px; background: Theme.border-subtle; }

                // Tree list with scrollbar. Tree nodes are navigation targets, but
                // they are also useful as search scopes, so each row has a small
                // checkbox and a right-click menu (#probe-folder-search).
                tree-area := Rectangle {
                    vertical-stretch: 1;
                    clip: true;

                    ScrollView {
                        width: parent.width;
                        height: parent.height;

                        tree-list := VerticalLayout {
                            spacing: 0;

                            for node[i] in root.tree-nodes : Rectangle {
                                height: 24px;
                                background: node-ta.has-hover
                                    ? Theme.bg-hover
                                    : (node.path == root.current-path
                                        ? #4a90e230
                                        : (node.path == root.tree-active-path
                                            ? #4a90e218
                                            : (mod(i, 2) == 0 ? transparent : #ffffff08)));

                                node-ta := TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    mouse-cursor: pointer;
                                    clicked => { /* Row body is handled by its own hit area; keep the row TouchArea for right-click only. */ }
                                    pointer-event(ev) => {
                                        if (ev.kind == PointerEventKind.down
                                                && ev.button == PointerEventButton.right) {
                                            root.tree-menu-target = node.path;
                                            root.tree-menu-x = self.absolute-position.x + self.mouse-x - tree-area.absolute-position.x;
                                            root.tree-menu-y = self.absolute-position.y + self.mouse-y - tree-area.absolute-position.y;
                                            tree-menu.show();
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 0;
                                    padding-top: 1px;

                                    // Depth indent spacer
                                    Rectangle { width: node.depth * 12px; }

                                    // Recursive folder selection. This only changes
                                    // the selection/search scope; it does not open or
                                    // expand the directory.
                                    Rectangle {
                                        width: 16px;
                                        y: (parent.height - self.height) / 2;
                                        height: 16px;
                                        border-radius: 3px;
                                        border-width: 1px;
                                        border-color: node.checked ? Theme.accent : Theme.border-strong;
                                        background: node.checked ? Theme.accent : transparent;
                                        tree-cb-ta := TouchArea {
                                            width: parent.width;
                                            height: parent.height;
                                            mouse-cursor: pointer;
                                            clicked => { root.toggle-tree-scope(node.path); }
                                        }
                                        if node.checked : Text {
                                            text: "\u{E5CA}";
                                            font-family: "Material Icons";
                                            color: #ffffff;
                                            font-size: 13px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width; height: parent.height;
                                        }
                                    }

                                    // Expand/collapse arrow. Single click here only
                                    // expands/collapses the tree; it never changes the
                                    // current address or file list.
                                    Rectangle {
                                        width: 16px;
                                        height: parent.height;
                                        arrow-ta := TouchArea {
                                            width: parent.width;
                                            height: parent.height;
                                            mouse-cursor: node.has-children ? pointer : default;
                                            clicked => { if (node.has-children) { root.tree-expand(node.path); } }
                                        }
                                        Text {
                                            width: parent.width;
                                            height: parent.height;
                                            text: node.has-children
                                                ? (node.expanded ? "▼" : "▶")
                                                : " ";
                                            color: arrow-ta.has-hover ? Theme.accent : Theme.text-muted;
                                            font-size: 9px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    // Folder name. Single click selects this directory
                                    // only; double click opens it and updates the path bar.
                                    Rectangle {
                                        horizontal-stretch: 1;
                                        height: parent.height;
                                        name-ta := TouchArea {
                                            width: parent.width;
                                            height: parent.height;
                                            mouse-cursor: pointer;
                                            clicked => { root.tree-active-path = node.path; }
                                            double-clicked => { root.navigate(node.path); }
                                        }
                                        Text {
                                            text: node.depth == 0 ? "/" : node.name;
                                            color: node.path == root.current-path
                                                ? Theme.accent
                                                : Theme.text-primary;
                                            font-size: Theme.fs-sm;
                                            width: parent.width;
                                            height: parent.height;
                                            overflow: elide;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    tree-menu := PopupWindow {
                        x: root.tree-menu-x;
                        y: root.tree-menu-y;
                        width: 156px;
                        height: 9 * 27px + 14px;
                        Rectangle {
                            background: Theme.bg-panel;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: Theme.border-strong;
                            drop-shadow-blur: 10px;
                            drop-shadow-color: #00000040;
                            VerticalLayout {
                                padding: 4px;
                                spacing: 1px;
                                SftpMenuItem {
                                    label: @tr("展开 / 折叠");
                                    clicked => { root.tree-expand(root.tree-menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("在此搜索");
                                    clicked => { root.search-folder(root.tree-menu-target, file-search.text); }
                                }
                                SftpMenuItem {
                                    label: @tr("复制路径");
                                    clicked => { root.copy-path(root.tree-menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("权限");
                                    enabled: root.tree-menu-target != "";
                                    clicked => { root.chmod-request(root.tree-menu-target, root.tree-menu-target, 493); }
                                }
                                Rectangle { height: 1px; background: Theme.border-subtle; }
                                SftpMenuItem {
                                    label: @tr("新建文件夹");
                                    clicked => { root.new-folder(root.tree-menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("新建文件");
                                    clicked => { root.new-file(root.tree-menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("刷新此目录");
                                    clicked => { root.refresh(root.tree-menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("刷新当前面板");
                                    clicked => { root.refresh(root.current-path); }
                                }
                                SftpMenuItem {
                                    label: @tr("删除文件夹");
                                    tint: #d86c6c;
                                    enabled: root.tree-menu-target != "/";
                                    clicked => { root.delete(root.tree-menu-target); }
                                }
                            }
                        }
                    }
                }            }

            // Vertical splitter: keep the visible divider as a thin Win11-style
            // hairline, not a glowing block. The transparent 7px hit area still
            // makes it easy to drag left/right without adding visual noise.
            if root.show-tree : Rectangle {
                width: 7px;
                background: transparent;
                Rectangle {
                    x: 3px;
                    width: 1px;
                    height: parent.height;
                    background: split-ta.has-hover || root.tree-resizing ? Theme.border-strong : Theme.border-subtle;
                }
                split-ta := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: ew-resize;
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                            root.tree-resizing = true;
                            root.tree-grab-x = self.absolute-position.x + self.mouse-x;
                            root.tree-base-width = root.tree-width;
                        }
                        if (e.kind == PointerEventKind.up) {
                            root.tree-resizing = false;
                        }
                    }
                    moved => {
                        if (root.tree-resizing) {
                            root.tree-width = clamp(
                                root.tree-base-width + (self.absolute-position.x + self.mouse-x - root.tree-grab-x),
                                120px,
                                min(420px, max(120px, root.width - 260px))
                            );
                        }
                    }
                }
            }

            // ── Right: file listing ─────────────────────────────────────────
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 0;

                // Column headers
                Rectangle {
                    height: 20px;
                    background: Theme.bg-root;
                    HorizontalLayout {
                        padding-left: 8px; padding-right: 8px; spacing: 8px;
                        // Spacer matching the rows' checkbox so the header columns
                        // line up with the values below them (#dock).
                        Rectangle { width: 16px; }
                        Text { text: @tr("Name"); color: Theme.text-muted; font-size: Theme.fs-xs;
                               horizontal-stretch: 1; vertical-alignment: center; }
                        if root.show-size-col : Text { text: @tr("Size"); color: Theme.text-muted; font-size: Theme.fs-xs;
                               width: 72px; horizontal-alignment: right; vertical-alignment: center; }
                        if root.show-modified-col : Text { text: @tr("Modified"); color: Theme.text-muted; font-size: Theme.fs-xs;
                               width: 116px; horizontal-alignment: right; vertical-alignment: center; }
                    }
                }
                Rectangle { height: 1px; background: Theme.border-subtle; }

                // File list. The area fills the panel height so right-click works
                // on the whitespace below the rows too (#84); the single menu
                // below greys out item actions when nothing was hit.
                file-area := Rectangle {
                    vertical-stretch: 1;
                    clip: true;
                    ScrollView {
                        width: parent.width;
                        height: parent.height;
                        viewport-width: self.visible-width;
                        viewport-height: max(self.visible-height, file-list.preferred-height);

                        file-list := VerticalLayout {
                            spacing: 0;

                            if root.loading : Rectangle {
                                height: 40px;
                                Text { text: @tr("Loading..."); color: Theme.text-muted; font-size: Theme.fs-sm;
                                       horizontal-alignment: center; vertical-alignment: center; }
                            }

                            if !root.loading && root.entries.length == 0 : Rectangle {
                                height: 40px;
                                Text { text: @tr("Empty directory"); color: Theme.text-muted; font-size: Theme.fs-sm;
                                       horizontal-alignment: center; vertical-alignment: center; }
                            }

                            for entry[i] in root.entries : row := Rectangle {
                                height: 24px;
                                background: entry.selected
                                    ? #4a90e235
                                    : (i == root.selected-row
                                        ? #4a90e240
                                        : (row-ta.has-hover
                                            ? #4a90e225
                                            : (mod(i, 2) == 0 ? transparent : #ffffff08)));

                                row-ta := TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    mouse-cursor: pointer;
                                    clicked => {
                                        if (entry.is-dir) {
                                            root.navigate(entry.full-path);
                                        } else {
                                            root.selected-row = i;
                                        }
                                    }
                                    double-clicked => {
                                        if (entry.is-dir) {
                                            root.navigate(entry.full-path);
                                        } else {
                                            root.download(entry.full-path);
                                        }
                                    }
                                    pointer-event(ev) => {
                                        if (ev.kind == PointerEventKind.down
                                                && ev.button == PointerEventButton.right) {
                                            root.selected-row = i;
                                            root.menu-target = entry.full-path;
                                            root.menu-target-name = entry.name;
                                            root.menu-target-is-dir = entry.is-dir;
                                            root.menu-target-mode = entry.mode;
                                            root.menu-target-index = i;
                                            root.menu-x = self.absolute-position.x + self.mouse-x - file-area.absolute-position.x;
                                            root.menu-y = self.absolute-position.y + self.mouse-y - file-area.absolute-position.y;
                                            file-menu.show();
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: 8px; padding-right: 8px; spacing: 8px;
                                    // Multi-select checkbox (#100). Its own TouchArea
                                    // sits above the row, so toggling doesn't trigger
                                    // navigate/select.
                                    Rectangle {
                                        width: 16px;
                                        y: (parent.height - self.height) / 2;
                                        height: 16px;
                                        border-radius: 3px;
                                        border-width: 1px;
                                        border-color: entry.selected ? Theme.accent : Theme.border-strong;
                                        background: entry.selected ? Theme.accent : transparent;
                                        cb-ta := TouchArea {
                                            width: parent.width;
                                            height: parent.height;
                                            mouse-cursor: pointer;
                                            clicked => { root.toggle-select(i); }
                                        }
                                        if entry.selected : Text {
                                            text: "\u{E5CA}"; // check
                                            font-family: "Material Icons";
                                            color: #ffffff;
                                            font-size: 13px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width; height: parent.height;
                                        }
                                    }
                                    Text {
                                        text: entry.is-dir ? "📁 " + entry.name : "📄 " + entry.name;
                                        color: entry.is-dir ? Theme.accent : Theme.text-primary;
                                        font-size: Theme.fs-sm;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }
                                    if root.show-size-col : Text {
                                        text: entry.is-dir ? "" : entry.size;
                                        color: Theme.text-secondary; font-size: Theme.fs-xs;
                                        width: 72px; horizontal-alignment: right; vertical-alignment: center;
                                    }
                                    if root.show-modified-col : Text {
                                        text: entry.modified;
                                        color: Theme.text-muted; font-size: Theme.fs-xs;
                                        width: 116px; horizontal-alignment: right; vertical-alignment: center;
                                    }
                                }
                            }

                            // Whitespace below the rows: right-click here opens the
                            // menu with no target (item actions greyed out) (#84).
                            ws := Rectangle {
                                vertical-stretch: 1;
                                min-height: 24px;
                                ws-ta := TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    pointer-event(ev) => {
                                        if (ev.kind == PointerEventKind.down
                                                && ev.button == PointerEventButton.right) {
                                            root.selected-row = -1;
                                            root.menu-target = "";
                                            root.menu-target-index = -1;
                                            root.menu-x = self.absolute-position.x + self.mouse-x - file-area.absolute-position.x;
                                            root.menu-y = self.absolute-position.y + self.mouse-y - file-area.absolute-position.y;
                                            file-menu.show();
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // One context menu for the whole list (#84). Item actions are
                    // enabled only when an item was right-clicked (menu-target set);
                    // new/refresh are always available.
                    file-menu := PopupWindow {
                        x: root.menu-x;
                        y: root.menu-y;
                        width: 154px;
                        height: 13 * 27px + 14px;
                        Rectangle {
                            background: Theme.bg-panel;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: Theme.border-strong;
                            drop-shadow-blur: 10px;
                            drop-shadow-color: #00000040;
                            VerticalLayout {
                                padding: 4px;
                                spacing: 1px;
                                SftpMenuItem {
                                    label: @tr("在此搜索");
                                    enabled: root.menu-target != "" && root.menu-target-is-dir;
                                    clicked => { root.search-folder(root.menu-target, file-search.text); }
                                }
                                Rectangle { height: 1px; background: Theme.border-subtle; }
                                SftpMenuItem {
                                    label: @tr("下载");
                                    enabled: root.menu-target != "";
                                    clicked => { root.download(root.menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("查看");
                                    enabled: root.menu-target != "" && !root.menu-target-is-dir;
                                    clicked => { root.view(root.menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("编辑");
                                    enabled: root.menu-target != "" && !root.menu-target-is-dir;
                                    clicked => { root.edit(root.menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("外部程序查看");
                                    enabled: root.menu-target != "" && !root.menu-target-is-dir;
                                    clicked => { root.open-external(root.menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("外部程序编辑");
                                    enabled: root.menu-target != "" && !root.menu-target-is-dir;
                                    clicked => { root.edit-external(root.menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("重命名");
                                    enabled: root.menu-target != "";
                                    clicked => { root.rename-request(root.menu-target, root.menu-target-name); }
                                }
                                SftpMenuItem {
                                    label: @tr("权限");
                                    enabled: root.menu-target != "";
                                    clicked => { root.chmod-request(root.menu-target, root.menu-target-name, root.menu-target-mode); }
                                }
                                SftpMenuItem {
                                    label: @tr("复制路径");
                                    enabled: root.menu-target != "";
                                    clicked => { root.copy-path(root.menu-target); }
                                }
                                SftpMenuItem {
                                    label: @tr("删除");
                                    tint: #d86c6c;
                                    enabled: root.menu-target != "";
                                    clicked => { root.delete(root.menu-target); }
                                }
                                Rectangle { height: 1px; background: Theme.border-subtle; }
                                SftpMenuItem {
                                    label: @tr("新建文件夹");
                                    clicked => { root.new-folder(root.current-path); }
                                }
                                SftpMenuItem {
                                    label: @tr("新建文件");
                                    clicked => { root.new-file(root.current-path); }
                                }
                                SftpMenuItem {
                                    label: @tr("刷新当前目录");
                                    clicked => { root.refresh(root.current-path); }
                                }
                            }
                        }
                    }
                }
            }
        }

        // --- Status bar (full width) --------------------------------------
        Rectangle {
            height: 18px;
            background: Theme.bg-panel-alt;
            Text {
                x: 8px;
                text: root.toolbar-tip != ""
                    ? "提示: " + root.toolbar-tip
                    : root.status
                        + (root.tree-active-path != "" ? "  ·  已选中: " + root.tree-active-path : "")
                        + (root.tree-scope != "" ? "  ·  搜索范围: " + root.tree-scope : "");
                color: Theme.text-muted;
                font-size: Theme.fs-xs;
                vertical-alignment: center;
                height: parent.height;
                overflow: elide;
                width: parent.width - 16px;
            }
        }
    }
}
