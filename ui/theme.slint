// Central design tokens for Probe Shell.
//
// Direction: practical Windows 11-style surfaces. Dark mode may keep the
// immersive wallpaper; light mode is intentionally opaque, muted and readable
// so terminal/SFTP text never turns into a white haze.

export global Theme {
    // Set by Rust on startup (system detection) and on user toggle.
    in-out property <bool> dark: true;

    // --- Immersive wallpaper (set by Rust from the wallpaper module) -------
    // When a wallpaper is active the window paints `wallpaper` behind everything
    // (see app.slint), panels/terminal frost over it, accent + surfaces shift
    // toward the image's colours, and Rust sets `dark` from the image luminance.
    in-out property <image> wallpaper;
    in-out property <bool>  wallpaper-active: false;
    in-out property <color> wp-accent: #4a90e2;   // vivid accent from the image
    in-out property <color> wp-tint:   #808080;   // average colour, tints surfaces
    // Frosted-panel opacity over a wallpaper (0.40–1.00). User-adjustable via the
    // Interface › Wallpaper opacity slider; bg-root / term-bg derive from it so one
    // control scales the whole wallpaper wash. Default 0.86 (#v0.5).
    in-out property <float> panel-alpha: 0.86;
    property <float> tint-amt: 0.10;              // how far surfaces pull to wp-tint

    // Frost a base surface: pull it slightly toward the wallpaper tint and make
    // it translucent so the image shows through. Returns the plain base colour
    // when no wallpaper is active (so the normal opaque theme is unchanged).
    pure function frost(base: color, alpha: float) -> brush {
        // Wallpaper immersion is intentionally dark-mode only. In light mode the
        // old frosted surfaces became a grey/white wash over the sci-fi wallpaper,
        // making text and SFTP tables hard to read. Keep light mode crisp and
        // opaque while preserving the immersive wallpaper in dark mode.
        return root.wallpaper-active && root.dark
            ? base.mix(root.wp-tint, 1.0 - root.tint-amt).with-alpha(alpha)
            : base;
    }

    // --- Palette -----------------------------------------------------------
    // Opaque window base — the wallpaper Image covers it when active, so panels
    // frost over the image rather than over this.
    out property <brush> window-base: dark ? #070a12 : #dbeaf7;

    property <color> base-bg-root:      dark ? #090f1f : #dbeaf7;
    property <color> base-bg-panel:     dark ? #111827 : #edf6ff;
    property <color> base-bg-panel-alt: dark ? #162033 : #e4f0fb;
    property <color> base-bg-elevated:  dark ? #1e2a44 : #f5faff;
    property <color> base-bg-hover:     dark ? #243453 : #d8e8f7;
    property <color> base-bg-active:    dark ? #2c4168 : #c8ddf5;

    // bg-root frosts lighter (lower alpha) so the wallpaper reads clearly in
    // empty / inset areas; panels stay mostly opaque for legible text.
    out property <brush> bg-root:      frost(base-bg-root, max(0.0, root.panel-alpha - 0.44));
    out property <brush> bg-panel:     frost(base-bg-panel, root.panel-alpha);
    out property <brush> bg-panel-alt: frost(base-bg-panel-alt, root.panel-alpha);
    out property <brush> bg-elevated:  frost(base-bg-elevated, root.panel-alpha);
    out property <brush> bg-hover:     frost(base-bg-hover, min(1.0, root.panel-alpha + 0.04));
    out property <brush> bg-active:    frost(base-bg-active, min(1.0, root.panel-alpha + 0.08));
    // Settings dialog: 20% less transparent than the other panels so its dense
    // grey labels stay legible even at a low wallpaper overlay (user request).
    out property <brush> bg-panel-strong: frost(base-bg-panel, min(1.0, root.panel-alpha + 0.20));

    out property <brush> border-subtle: dark ? #ffffff18 : #c7d7e8;
    out property <brush> border-strong: dark ? #8bd5ff55 : #8aa8c9;

    out property <brush> text-primary:   dark ? #edf6ff : #172033;
    // Light-mode secondary/muted darkened further (was #55555a / #7c7c82): over a
    // see-through frosted-wallpaper panel the greys were still too faint to read.
    out property <brush> text-secondary: dark ? #b9c7dc : #46576c;
    out property <brush> text-muted:     dark ? #8290a8 : #5f7086;

    out property <brush> accent:         (root.wallpaper-active && root.dark) ? root.wp-accent          : (dark ? #59b8ff : #3178d4);
    out property <brush> accent-hover:   (root.wallpaper-active && root.dark) ? root.wp-accent.brighter(0.12) : (dark ? #7cc8ff : #4489e1);
    out property <brush> accent-pressed: (root.wallpaper-active && root.dark) ? root.wp-accent.darker(0.12)   : (dark ? #2f8fd3 : #2264b5);

    out property <brush> success: dark ? #52d6b8 : #16a34a;
    out property <brush> warning: dark ? #f4c067 : #f59e0b;
    out property <brush> danger:  dark ? #ff6b7a : #ef4444;

    // Terminal uses its own background so it stays readable regardless of
    // what the shell / remote app outputs via ANSI colour codes. With a
    // wallpaper it frosts (kept neutral, not tinted) so text stays legible.
    property <color> base-term-bg: dark ? #050914 : #edf5ff;
    out property <brush> term-bg: (root.wallpaper-active && root.dark) ? base-term-bg.with-alpha(max(0.0, root.panel-alpha - 0.14)) : base-term-bg;
    out property <brush> term-fg: dark ? #d4d4d4 : #172033;

    // True on macOS (set by Rust). App shortcuts use Cmd (⌘) here instead of
    // Ctrl, so the physical Ctrl key stays free for the shell (^C/^X…) (#158).
    in-out property <bool> is-mac: false;

    // Whether the app window is focused & visible. Rust drives this from winit
    // focus/minimize/occlusion events; the terminal cursor stops blinking when
    // it's false, so an idle background window doesn't repaint (#127).
    in-out property <bool> window-focused: true;

    // Global UI scale (#100/#117/#118). Rust sets this from the saved setting;
    // all font sizes and spacing/radii below multiply by it, so the whole UI
    // grows/shrinks live (the terminal font has its own size setting).
    in-out property <float> ui-scale: 1.0;
    // Settings-panel font scale (#v0.5). The settings card + its text multiply by
    // this so the panel (which is exempt from ui-scale) can still be enlarged.
    in-out property <float> panel-font: 1.0;

    // --- Typography --------------------------------------------------------
    out property <length> fs-xs: 11px * root.ui-scale;
    out property <length> fs-sm: 12px * root.ui-scale;
    out property <length> fs-md: 13px * root.ui-scale;
    out property <length> fs-lg: 15px * root.ui-scale;
    out property <length> fs-xl: 18px * root.ui-scale;

    // Embedded glyph-complete monospace (Cascadia Mono under a unique name, #114).
    out property <string> font-mono: "Meatshell Mono";

    // UI (sans) font for editable inputs. The embedded mono font has no CJK
    // glyphs and native TextInput doesn't glyph-fallback like Text does, so
    // typing Chinese into a bare TextInput renders tofu. Rust sets this to a
    // CJK-capable system font on startup (empty = platform default).
    in-out property <string> ui-font-family: "";

    // Terminal font — user-configurable via Interface settings, set by Rust
    // from the config on startup. cell size in terminal_view derives from these.
    in-out property <string> term-font-family: "Meatshell Mono";
    in-out property <length> term-font-size: 13px;

    // --- Geometry ----------------------------------------------------------
    out property <length> radius-sm: 8px * root.ui-scale;
    out property <length> radius-md: 12px * root.ui-scale;
    out property <length> radius-lg: 18px * root.ui-scale;

    out property <length> gap-xs: 4px * root.ui-scale;
    out property <length> gap-sm: 8px * root.ui-scale;
    out property <length> gap-md: 12px * root.ui-scale;
    out property <length> gap-lg: 16px * root.ui-scale;
}
