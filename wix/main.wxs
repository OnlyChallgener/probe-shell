<?xml version="1.0" encoding="windows-1252"?>
<!--
  WiX (v3) installer definition for probe-shell, driven by `cargo wix`.

  cargo-wix injects these preprocessor variables:
    $(var.Version)            crate version from Cargo.toml
    $(var.CargoTargetBinDir)  e.g. target\x86_64-pc-windows-msvc\release

  The `WixUI_InstallDir` UI (bottom) gives the user a "Browse..." page so the
  install directory can be changed, which is the whole point of shipping an MSI.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product
        Id="*"
        Name="Probe Shell"
        UpgradeCode="9C5F3A52-8D6B-4C0A-9B42-7E0A1F8D2C61"
        Manufacturer="Probe Shell contributors"
        Language="1033"
        Codepage="1252"
        Version="$(var.Version)">

        <Package Id="*"
            Keywords="Installer"
            Description="Probe Shell - lightweight SSH/SFTP terminal client"
            Manufacturer="Probe Shell contributors"
            InstallerVersion="450"
            Languages="1033"
            Compressed="yes"
            InstallScope="perMachine"
            SummaryCodepage="1252"/>

        <!-- Replace an older install in place instead of erroring out. -->
        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of Probe Shell is already installed. Setup will now exit."/>

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1"/>
        <Property Id="DiskPrompt" Value="Probe Shell Installation"/>

        <Icon Id="ProductICO" SourceFile="assets\probe-shell.ico"/>
        <Property Id="ARPPRODUCTICON" Value="ProductICO"/>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder">
                <!-- Default path; the InstallDir UI lets the user change it. -->
                <Directory Id="APPLICATIONFOLDER" Name="Probe Shell">
                    <Component Id="MainExecutable" Guid="*">
                        <File Id="ProbeShellEXE"
                              Name="probe-shell.exe"
                              Source="$(var.CargoTargetBinDir)\probe-shell.exe"
                              KeyPath="yes"/>
                    </Component>
                </Directory>
            </Directory>
            <Directory Id="ProgramMenuFolder">
                <Component Id="ApplicationShortcut" Guid="*">
                    <Shortcut Id="StartMenuShortcut"
                        Name="Probe Shell"
                        Description="Lightweight SSH/terminal client"
                        Target="[APPLICATIONFOLDER]probe-shell.exe"
                        WorkingDirectory="APPLICATIONFOLDER"
                        Icon="ProductICO"/>
                    <RemoveFolder Id="CleanUpShortCut" On="uninstall"/>
                    <RegistryValue Root="HKCU"
                        Key="Software\ProbeShell"
                        Name="installed"
                        Type="integer"
                        Value="1"
                        KeyPath="yes"/>
                </Component>
            </Directory>
        </Directory>

        <Feature Id="MainProgram" Title="Probe Shell" Level="1">
            <ComponentRef Id="MainExecutable"/>
            <ComponentRef Id="ApplicationShortcut"/>
        </Feature>

        <!-- "Choose install location" wizard page (needs WixUIExtension). -->
        <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER"/>
        <UIRef Id="WixUI_InstallDir"/>
        <UIRef Id="WixUI_ErrorProgressText"/>
    </Product>
</Wix>
